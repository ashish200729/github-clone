GIT_SERVICE_PORT=8080
GIT_REPOSITORY_ROOT=/absolute/path/to/github-clone-data/repos
GIT_SERVICE_INTERNAL_TOKEN=replace-with-the-same-value-used-by-apps-api
GIT_TRANSPORT_TOKEN_SECRET=replace-with-the-same-value-used-by-apps-api
GIT_HTTP_BASE_PATH=/git

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/github_clone
DATABASE_SSL=disable
