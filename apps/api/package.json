{
  "name": "@github-clone/api",
  "version": "1.0.0",
  "private": true,
  "description": "Minimal Express starter.",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "dev:worker": "tsx watch src/worker.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "start:worker": "node dist/worker.js",
    "db:migrate": "DOTENV_CONFIG_QUIET=true node-pg-migrate -m migrations --envPath .env up",
    "db:rollback": "DOTENV_CONFIG_QUIET=true node-pg-migrate -m migrations --envPath .env down",
    "db:status": "tsx src/db/status.ts",
    "test": "node --import tsx --test test/**/*.test.ts",
    "lint": "tsc --noEmit -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "keywords": [
    "express",
    "api"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "bullmq": "^5.70.4",
    "dotenv": "^17.3.1",
    "express": "^5.1.0",
    "express-rate-limit": "^8.3.1",
    "helmet": "^8.1.0",
    "ioredis": "^5.10.0",
    "pg": "^8.20.0",
    "rate-limit-redis": "^4.3.1",
    "redis": "^5.11.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.3",
    "@types/node": "^24.6.0",
    "@types/pg": "^8.18.0",
    "node-pg-migrate": "^8.0.4",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}
