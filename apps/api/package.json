{
  "name": "@github-clone/api",
  "version": "1.0.0",
  "private": true,
  "description": "Minimal Express starter.",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "db:migrate": "DOTENV_CONFIG_QUIET=true node-pg-migrate -m migrations --envPath .env up",
    "db:rollback": "DOTENV_CONFIG_QUIET=true node-pg-migrate -m migrations --envPath .env down",
    "db:status": "tsx src/db/status.ts",
    "lint": "tsc --noEmit -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "keywords": [
    "express",
    "api"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "dotenv": "^17.3.1",
    "express": "^5.1.0",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.3",
    "@types/node": "^24.6.0",
    "@types/pg": "^8.18.0",
    "node-pg-migrate": "^8.0.4",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}
