API_PORT=4000
API_SHUTDOWN_TIMEOUT_MS=10000
INTERNAL_API_AUTH_SECRET=replace-with-the-same-value-used-by-apps-web
GIT_SERVICE_URL=http://localhost:8080
GIT_HTTP_BASE_URL=http://localhost:8080
GIT_HTTP_BASE_PATH=/git
GIT_SERVICE_INTERNAL_TOKEN=replace-with-a-shared-secret-for-the-go-git-service
GIT_TRANSPORT_TOKEN_SECRET=replace-with-a-shared-secret-for-git-cli-access
GIT_TRANSPORT_TOKEN_TTL_SECONDS=43200

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/github_clone
DATABASE_POOL_MAX=10
DATABASE_IDLE_TIMEOUT_MS=30000
DATABASE_CONNECTION_TIMEOUT_MS=10000
DATABASE_SSL=disable

REDIS_URL=redis://localhost:6379
REDIS_KEY_PREFIX=ghclone:api:
REDIS_CONNECT_TIMEOUT_MS=10000
REDIS_REQUIRED=true
